# ============================================================
# AI Agent Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# OpenAI API Key (required for LLM-based SQL generation)
OPENAI_API_KEY=

# LLM Model to use
LLM_MODEL=gpt-4o

# Redis URL for session memory
REDIS_URL=redis://localhost:6379/0

# Application Secret Key (for JWT signing)
SECRET_KEY=change-me-to-a-strong-random-secret

# Encryption Key (Fernet key for credential storage)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=your-fernet-encryption-key-here

# Application Database URL
APP_DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/ai_agent_db

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
